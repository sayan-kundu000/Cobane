# Database Config
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cobane

# Security Config
JWT_SECRET_KEY=replace_with_a_secure_jwt_secret_key_at_least_32_characters_long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Service Provider Config
AI_PROVIDER=openai
AI_API_KEY=your-openai-or-compatible-api-key
AI_BASE_URL=https://api.openai.com/v1

# Server Config
BACKEND_PORT=8000
FRONTEND_PORT=3000
ENVIRONMENT=development
